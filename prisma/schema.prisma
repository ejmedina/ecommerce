// ============================================
// Ecommerce Base - Prisma Schema
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS (Unified Auth)
// ============================================

enum UserRole {
  SUPERADMIN
  OWNER
  ADMIN
  CUSTOMER
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?
  name         String?
  phone        String?
  pendingEmail String?   // Email pendiente de verificación
  role         UserRole  @default(CUSTOMER)
  status       String    @default("ACTIVE") // ACTIVE | BLOCKED
  newsletter   Boolean   @default(false)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  addresses    Address[]
  orders       Order[]
  cart         Cart?
  auditLogs    AuditLog[]
  routeSheets  RouteSheet[]

  @@map("users")
}

model Address {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  label        String
  street       String
  number       String
  floor        String?
  apartment    String?
  city         String
  state        String
  postalCode   String
  country      String   @default("AR")
  instructions String?
  isDefault    Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("addresses")
}

// ============================================
// CATALOG
// ============================================

model Brand {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  logo      String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]

  @@map("brands")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  parentId    String?
  parent      Category? @relation("Subcategories", fields: [parentId], references: [id])
  children    Category[] @relation("Subcategories")
  isActive    Boolean   @default(true)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@map("categories")
}

model Product {
  id              String       @id @default(cuid())
  name            String
  slug            String       @unique
  description     String?
  brandId         String?
  brand           Brand?       @relation(fields: [brandId], references: [id])
  categoryId      String?
  category        Category?    @relation(fields: [categoryId], references: [id])

  sku             String?      @unique
  stock           Int          @default(0)

  price           Decimal      @db.Decimal(10, 2)
  comparePrice    Decimal?     @db.Decimal(10, 2)

  images          ProductImage[]

  isFeatured      Boolean      @default(false)
  isActive        Boolean      @default(false)
  publishedAt     DateTime?

  metaTitle       String?
  metaDescription String?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  cartItems       CartItem[]
  orderItems      OrderItem[]

  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("product_images")
}

// ============================================
// CART
// ============================================

model Cart {
  id         String     @id @default(cuid())
  userId     String?    @unique
  user       User?      @relation(fields: [userId], references: [id])
  sessionId  String?    @unique
  items      CartItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@map("carts")
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)

  @@unique([cartId, productId])
  @@map("cart_items")
}

// ============================================
// ORDERS
// ============================================

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  MERCADOPAGO
  BANK_TRANSFER
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  CANCELLED
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique

  userId          String
  user            User          @relation(fields: [userId], references: [id])

  status          OrderStatus   @default(PENDING)

  items           OrderItem[]

  subtotal        Decimal       @db.Decimal(10, 2)
  shippingCost    Decimal       @db.Decimal(10, 2) @default(0)
  taxAmount       Decimal       @db.Decimal(10, 2) @default(0)
  discountAmount  Decimal       @db.Decimal(10, 2) @default(0)
  total           Decimal       @db.Decimal(10, 2)

  shippingMethod  String
  shippingAddress Json
  billingAddress  Json?

  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(PENDING)
  mercadopagoId   String?
  mercadopagoData Json?

  customerNotes   String?
  adminNotes      String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  paidAt          DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?

  routeSheetItems RouteSheetItem[]

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])

  name      String
  sku       String?
  price     Decimal  @db.Decimal(10, 2)
  quantity  Int
  total     Decimal  @db.Decimal(10, 2)

  @@map("order_items")
}

// ============================================
// ROUTE SHEET
// ============================================

model RouteSheet {
  id          String            @id @default(cuid())
  name        String
  date        DateTime          @db.Date
  notes       String?
  createdById String
  createdBy   User              @relation(fields: [createdById], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  items       RouteSheetItem[]

  @@map("route_sheets")
}

model RouteSheetItem {
  id           String     @id @default(cuid())
  routeSheetId String
  routeSheet   RouteSheet @relation(fields: [routeSheetId], references: [id], onDelete: Cascade)
  orderId      String
  order        Order      @relation(fields: [orderId], references: [id])
  position     Int
  notes        String?

  @@unique([routeSheetId, orderId])
  @@map("route_sheet_items")
}

// ============================================
// SETTINGS
// ============================================

model StoreSettings {
  id                  String   @id @default(cuid())
  storeName           String   @default("Mi Tienda")
  storeEmail          String?
  storePhone          String?
  storeAddress        Json?
  
  // Logo and favicon
  logo                String?
  logoWidth           Int?
  logoHeight          Int?
  favicon             String?
  faviconWidth        Int?
  faviconHeight       Int?
  
  // Shipping configuration (JSON structure for flexibility)
  shippingConfig      Json?    // { zones: [{ id, name, provinces, cities?, cost, freeFrom, isActive }] }
  
  // Legacy fields (for backward compatibility)
  freeShippingMin     Decimal  @db.Decimal(10, 2) @default(0)
  fixedShippingCost   Decimal  @db.Decimal(10, 2) @default(0)
  
  bankAccount         Json?    // {bank, cbu, alias, name}
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("store_settings")
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  entity    String
  entityId  String
  action    String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  userType  String?
  data      Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@map("audit_logs")
}

// ============================================
// VERIFICATION TOKENS
// ============================================

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  type       String   // PASSWORD_SETUP | EMAIL_VERIFICATION | etc
  expires    DateTime

  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@map("verification_tokens")
}
