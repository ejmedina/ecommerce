// ============================================
// Ecommerce Base - Prisma Schema
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS (Unified Auth)
// ============================================

enum UserRole {
  SUPERADMIN
  OWNER
  ADMIN
  CUSTOMER
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?
  name         String?
  phone        String?
  pendingEmail String?   // Email pendiente de verificación
  role         UserRole  @default(CUSTOMER)
  status       String    @default("ACTIVE") // ACTIVE | BLOCKED
  newsletter   Boolean   @default(false)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  addresses    Address[]
  orders       Order[]
  cart         Cart?
  auditLogs    AuditLog[]
  routeSheets  RouteSheet[]

  @@map("users")
}

model Address {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  label        String
  street       String
  number       String
  floor        String?
  apartment    String?
  city         String
  state        String
  postalCode   String
  country      String   @default("AR")
  instructions String?
  isDefault    Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("addresses")
}

// ============================================
// CATALOG
// ============================================


model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  parentId    String?
  parent      Category? @relation("Subcategories", fields: [parentId], references: [id])
  children    Category[] @relation("Subcategories")
  isActive    Boolean   @default(true)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@map("categories")
}

model Product {
  id              String       @id @default(cuid())
  name            String
  slug            String       @unique
  description     String?
  categoryId      String?
  category        Category?    @relation(fields: [categoryId], references: [id])

  sku             String?      @unique
  stock           Int          @default(0)
  hasPermanentStock Boolean    @default(false)

  price           Decimal      @db.Decimal(10, 2)
  comparePrice    Decimal?     @db.Decimal(10, 2)

  images          ProductImage[]

  isFeatured      Boolean      @default(false)
  isActive        Boolean      @default(false)
  publishedAt     DateTime?

  metaTitle       String?
  metaDescription String?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  cartItems       CartItem[]
  orderItems      OrderItem[]

  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("product_images")
}

// ============================================
// CART
// ============================================

model Cart {
  id         String     @id @default(cuid())
  userId     String?    @unique
  user       User?      @relation(fields: [userId], references: [id])
  sessionId  String?    @unique
  items      CartItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@map("carts")
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)

  @@unique([cartId, productId])
  @@map("cart_items")
}

// ============================================
// ORDERS - Simplified Status Model with 2 Axes
// ============================================

// Eje 1: Estado de Negocio/Operativo
enum OrderStatus {
  RECEIVED              // Pedido recibido
  CONFIRMED            // Confirmado
  PREPARING           // En preparación
  READY_FOR_DELIVERY   // Listo para entregar/repartir
  OUT_FOR_DELIVERY    // En reparto
  DELIVERED           // Entregado
  NOT_DELIVERED       // No entregado (requiere motivo)
  CANCELLED           // Cancelado
}

// Eje 2: Modalidad de Pago
enum PaymentMethod {
  ONLINE_CARD          // Tarjeta online (MercadoPago, Stripe)
  BANK_TRANSFER        // Transferencia bancaria
  DIGITAL_WALLET       // Wallet digital (MercadoPago, etc.)
  CASH_ON_DELIVERY    // Efectivo al entregar
  CARD_ON_DELIVERY    // Tarjeta al entregar
  TRANSFER_ON_DELIVERY // Transferencia al entregar
}

// Eje 3: Estado del Cobro
enum PaymentStatus {
  PENDING              // Pendiente de cobro
  AUTHORIZED          // Reservado/autorizado
  PAID                // Cobrado
  PARTIALLY_REFUNDED  // Reembolso parcial
  REFUNDED            // Reembolsado completamente
  FAILED              // Falló el cobro
  VOIDED              // Anulado/sin efecto
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique

  userId          String
  user            User          @relation(fields: [userId], references: [id])

  // === ESTADO DE NEGOCIO (Eje 1) ===
  orderStatus     OrderStatus   @default(RECEIVED)

  // === ESTADO DE PAGO (Eje 2 y 3) ===
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(PENDING)

  items              OrderItem[]

  subtotal           Decimal       @db.Decimal(10, 2)
  shippingCost       Decimal       @db.Decimal(10, 2) @default(0)
  taxAmount          Decimal       @db.Decimal(10, 2) @default(0)
  discountAmount     Decimal       @db.Decimal(10, 2) @default(0)
  total              Decimal       @db.Decimal(10, 2)
  
  // Total según lo preparado (para faltantes)
  fulfilledTotal     Decimal?      @db.Decimal(10, 2)

  shippingMethod     String
  shippingAddress    Json
  billingAddress     Json?

  mercadopagoId      String?
  mercadopagoData    Json?

  customerNotes      String?
  adminNotes         String?

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  paidAt             DateTime?
  cancelledAt        DateTime?

  routeSheetItems    RouteSheetItem[]

  @@map("orders")
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product  @relation(fields: [productId], references: [id])

  name            String
  sku             String?
  price           Decimal  @db.Decimal(10, 2)
  
  // Cantidad ordenada originalmente
  quantityOrdered  Int
  
  // Precio unitario (era "total" en el modelo old, ahora es price * quantityOrdered)
  unitTotal       Decimal  @db.Decimal(10, 2)

  // === CAMPOS PARA FALTANTES ===
  quantityFulfilled Int?    @default(0)   // Cantidad realmente preparada
  quantityMissing   Int?    @default(0)   // Cantidad faltante
  missingReason     String?              // Motivo opcional
  fulfilledAt       DateTime?            // Cuándo se marcó como preparado

  @@map("order_items")
}

// ============================================
// ROUTE SHEET
// ============================================

enum RouteSheetStatus {
  DRAFT
  IN_PREPARATION
  IN_DELIVERY
  COMPLETED
  CANCELLED
}

enum DeliveryFailureReason {
  CUSTOMER_NOT_HOME
  WRONG_ADDRESS
  INACCESSIBLE_LOCATION
  CUSTOMER_REFUSED
  OTHER
}

model RouteSheet {
  id          String            @id @default(cuid())
  name        String
  date        DateTime          @db.Date
  notes       String?
  status      RouteSheetStatus @default(DRAFT)
  createdById String
  createdBy   User              @relation(fields: [createdById], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  items       RouteSheetItem[]

  @@map("route_sheets")
}

model RouteSheetItem {
  id           String     @id @default(cuid())
  routeSheetId String
  routeSheet   RouteSheet @relation(fields: [routeSheetId], references: [id], onDelete: Cascade)
  orderId      String
  order        Order      @relation(fields: [orderId], references: [id])
  position     Int
  notes        String?

  // Outcome de entrega (reemplaza DeliveryResult)
  deliveryOutcome        String?                // DELIVERED | NOT_DELIVERED
  deliveryFailureReason  DeliveryFailureReason?
  deliveryNotes         String?
  deliveredAt          DateTime?

  @@unique([routeSheetId, orderId])
  @@map("route_sheet_items")
}

// ============================================
// SETTINGS
// ============================================

model StoreSettings {
  id                  String   @id @default(cuid())
  storeName           String   @default("Mi Tienda")
  storeEmail          String?
  storePhone          String?
  storeAddress        Json?
  
  // Logo and favicon
  logo                String?
  logoWidth           Int?
  logoHeight          Int?
  favicon             String?
  faviconWidth        Int?
  faviconHeight       Int?
  
  // Shipping configuration (JSON structure for flexibility)
  shippingConfig      Json?    // { zones: [{ id, name, provinces, cities?, cost, freeFrom, isActive }] }
  
  // Legacy fields (for backward compatibility)
  freeShippingMin     Decimal  @db.Decimal(10, 2) @default(0)
  fixedShippingCost   Decimal  @db.Decimal(10, 2) @default(0)
  
  bankAccount         Json?    // {bank, cbu, alias, name}
  
  // === CONFIGURACIÓN DE MEDIOS DE PAGO ===
  // {"CASH_ON_DELIVERY": {isActive: true}, "BANK_TRANSFER": {isActive: true}, ...}
  paymentMethods      Json?

  // === CONFIGURACIÓN DE FLUJO DE PEDIDOS ===
  // true = al crear un pedido pasa directamente a CONFIRMED
  // false = el pedido queda en RECEIVED y requiere confirmación manual
  autoConfirmOrders   Boolean  @default(true)
  
  // === CONFIGURACIÓN DE FLUJO DE PAGO ===
  // true = solo avanzar fulfillment si paymentStatus = PAID
  // false = avanzar aunque paymentStatus = PENDING (contra entrega)
  requiresPaymentToFulfill Boolean @default(false)
  
  // === CONFIGURACIÓN DE WHATSAPP ===
  // Mensaje personalizado para notificar al cliente cuando el pedido está por llegar
  // Usa %s para el nombre de la tienda (se reemplaza automáticamente)
  whatsappPreArrivalMessage String? @db.Text
  
  // === CONFIGURACIÓN DE COLORES DEL TEMA ===
  // Colores personalizables de la tienda
  // Estructura: { primary, secondary, accent, background, foreground, border, muted, destructive, ... }
  themeColors         Json?    @default("{\"primary\":\"#0a0a0a\",\"primaryForeground\":\"#ffffff\",\"secondary\":\"#f5f5f5\",\"secondaryForeground\":\"#0a0a0a\",\"accent\":\"#f5f5f5\",\"accentForeground\":\"#0a0a0a\",\"background\":\"#ffffff\",\"foreground\":\"#0a0a0a\",\"muted\":\"#f5f5f5\",\"mutedForeground\":\"#737373\",\"border\":\"#e5e5e5\",\"input\":\"#e5e5e5\",\"ring\":\"#0a0a0a\",\"destructive\":\"#dc2626\",\"destructiveForeground\":\"#ffffff\",\"card\":\"#ffffff\",\"cardForeground\":\"#0a0a0a\",\"popover\":\"#ffffff\",\"popoverForeground\":\"#0a0a0a\"}")

  // === CONFIGURACIÓN DE LA HOME PAGE ===
  // Hero/Slider de la home
  heroSliderEnabled   Boolean  @default(true)
  heroSlides          Json?    // [{ image, title, subtitle, ctaText, ctaLink }]
  
  // Tarjetas de categorías
  categoryCardsEnabled Boolean  @default(true)
  categoryCards        Json?    // [{ categoryId, image, title, subtitle, ctaText, ctaLink }]
  
  // Más vendidos
  bestSellersEnabled   Boolean  @default(true)
  bestSellersLimit     Int      @default(6)
  
  // Tarjetas informativas
  infoCardsEnabled     Boolean  @default(true)
  infoCards           Json?    // [{ icon, title, description }]
  
  // === CONFIGURACIÓN DEL DOMINIO ===
  // URL base de la tienda (ej: https://mi-tienda.com)
  // Se usa para generar enlaces en emails, etc.
  storeUrl            String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("store_settings")
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  entity    String
  entityId  String
  action    String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  userType  String?
  data      Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@map("audit_logs")
}

// ============================================
// VERIFICATION TOKENS
// ============================================

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  type       String   // PASSWORD_SETUP | EMAIL_VERIFICATION | etc
  expires    DateTime

  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@map("verification_tokens")
}
